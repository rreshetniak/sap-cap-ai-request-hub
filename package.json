{
  "name": "sap-cap-ai-request-hub",
  "version": "0.1.0",
  "dependencies": {
    "@sap/cds": "^9"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4"
  },
  "scripts": {
    "start": "cds-serve",
    "test": "node --test",
    "test:read": "node --test test/request-service-read.test.js",
    "test:lifecycle": "node --test test/request-lifecycle-submit.test.js test/request-lifecycle-negative.test.js test/request-lifecycle-approve.test.js"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": {
        "[development]": {
          "kind": "mocked",
          "users": {
            "requester": {
              "password": "requester",
              "roles": ["Requester"]
            },
            "processor": {
              "password": "processor",
              "roles": ["Processor"]
            },
            "admin": {
              "password": "admin",
              "roles": ["Admin"]
            }
          }
        }
      }
    }
  }
}
